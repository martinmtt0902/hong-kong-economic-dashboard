{
  "name": "hong-kong-economic-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "generate:data": "node --import tsx scripts/generate-dashboard.ts",
    "test:snapshots": "node --import tsx --test tests/snapshots/*.test.ts",
    "test:snapshots:refresh": "npm run generate:data && npm run test:snapshots",
    "test:invariants": "node --import tsx --test tests/invariants/*.test.ts",
    "test": "npm run test:snapshots && npm run test:invariants"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.2.1"
  }
}
